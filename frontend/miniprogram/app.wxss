/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

/* 容器样式 */
.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 标题样式 */
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 按钮样式 */
.btn {
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.btn-primary {
  background: #1890ff;
}

.btn-success {
  background: #52c41a;
}

.btn-warning {
  background: #faad14;
}

.btn-danger {
  background: #ff4d4f;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}
