/* 回测页面样式 */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

/* 策略列表 */
.strategy-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.strategy-item {
  padding: 16rpx 30rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.strategy-item.active {
  background: #1890ff;
  color: #fff;
}

/* 参数表单 */
.param-form {
  margin-top: 10rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
}

.input {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
  color: #333;
}

/* 运行按钮 */
.btn-run {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
}

/* 回测结果 */
.result-card {
  margin-top: 20rpx;
}

.result-section {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-section:last-child {
  border-bottom: none;
}

.result-item {
  flex: 1;
  text-align: center;
}

.result-item.highlight {
  border-right: 1rpx solid #f0f0f0;
}

.result-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.result-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.result-value.danger {
  color: #ff4d4f;
}
