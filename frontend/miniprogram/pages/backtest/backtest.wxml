<wxs module="filters">
/**
 * 格式化数值为固定小数位
 * @param {number} value - 要格式化的数值
 * @param {number} decimals - 小数位数，默认2位
 * @returns {string} 格式化后的字符串
 */
module.exports.toFixed = function(value, decimals) {
  if (value === null || value === undefined) return '0.00';
  decimals = decimals || 2;
  return Number(value).toFixed(decimals);
};

/**
 * 格式化收益率显示
 * @param {number} value - 收益率值
 * @returns {string} 带正负号的百分比字符串
 */
module.exports.formatPercent = function(value) {
  if (value === null || value === undefined) return '0.00%';
  var sign = value >= 0 ? '+' : '';
  return sign + Number(value).toFixed(2) + '%';
};
</wxs>

<view class="container">
  <!-- 策略选择 -->
  <view class="card">
    <text class="title">选择策略</text>
    <view class="strategy-list">
      <view 
        class="strategy-item {{selectedStrategy === item.key ? 'active' : ''}}"
        wx:for="{{strategies}}"
        wx:key="key"
        bindtap="onStrategySelect"
        data-key="{{item.key}}"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 参数设置 -->
  <view class="card">
    <text class="title">参数设置</text>
    <view class="param-form">
      <view class="form-item">
        <text class="label">股票代码</text>
        <input 
          class="input" 
          placeholder="如: 000001" 
          value="{{stockCode}}"
          bindinput="onInputChange"
          data-field="stockCode"
        />
      </view>
      <view class="form-item">
        <text class="label">开始日期</text>
        <picker mode="date" value="{{startDate}}" bindchange="onDateChange" data-field="startDate">
          <view class="picker-value">{{startDate}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">结束日期</text>
        <picker mode="date" value="{{endDate}}" bindchange="onDateChange" data-field="endDate">
          <view class="picker-value">{{endDate}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">初始资金</text>
        <input 
          class="input" 
          type="digit"
          placeholder="如: 100000" 
          value="{{initialCapital}}"
          bindinput="onInputChange"
          data-field="initialCapital"
        />
      </view>
    </view>
  </view>

  <!-- 运行回测 -->
  <button class="btn-run" bindtap="runBacktest" loading="{{running}}">
    {{running ? '回测中...' : '运行回测'}}
  </button>

  <!-- 回测结果 -->
  <view class="card result-card" wx:if="{{result}}">
    <text class="title">回测结果</text>
    
    <!-- 收益概览 -->
    <view class="result-section">
      <view class="result-item highlight">
        <text class="result-label">总收益率</text>
        <text class="result-value" style="color: {{result.total_return >= 0 ? '#ff4d4f' : '#52c41a'}}">
          {{filters.formatPercent(result.total_return)}}
        </text>
      </view>
      <view class="result-item">
        <text class="result-label">年化收益率</text>
        <text class="result-value">{{filters.toFixed(result.annual_return, 2)}}%</text>
      </view>
    </view>

    <!-- 风险指标 -->
    <view class="result-section">
      <view class="result-item">
        <text class="result-label">最大回撤</text>
        <text class="result-value danger">{{filters.toFixed(result.max_drawdown, 2)}}%</text>
      </view>
      <view class="result-item">
        <text class="result-label">夏普比率</text>
        <text class="result-value">{{filters.toFixed(result.sharpe_ratio, 2)}}</text>
      </view>
    </view>

    <!-- 交易统计 -->
    <view class="result-section">
      <view class="result-item">
        <text class="result-label">交易次数</text>
        <text class="result-value">{{result.total_trades}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">胜率</text>
        <text class="result-value">{{filters.toFixed(result.win_rate, 2)}}%</text>
      </view>
    </view>
  </view>
</view>
