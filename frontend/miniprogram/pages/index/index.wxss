/* 首页样式 */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.update-time {
  font-size: 24rpx;
  color: #999;
}

/* 市场概览 */
.market-overview .market-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.market-item {
  width: 48%;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  text-align: center;
}

.market-name {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.market-value {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.market-change {
  font-size: 24rpx;
}

/* 快捷功能 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
}

.action-item image {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 10rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #666;
}

/* 系统状态 */
.status-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-row:last-child {
  border-bottom: none;
}

.status-label {
  color: #666;
}

.status-value {
  font-weight: 500;
}

.status-value.online {
  color: #52c41a;
}

.status-value.offline {
  color: #ff4d4f;
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 22rpx;
}

.disclaimer text {
  display: block;
  margin-bottom: 8rpx;
}
