<wxs module="filters">
/**
 * 获取数组元素
 */
module.exports.getItem = function(arr, index) {
  if (!arr || arr.length === 0) return null;
  return arr[index] || null;
};

/**
 * 获取对象属性
 */
module.exports.get = function(obj, key) {
  if (!obj) return null;
  return obj[key] || null;
};

/**
 * 获取对象属性值
 */
module.exports.getVal = function(obj, prop) {
  if (!obj) return '--';
  var val = obj[prop];
  return (val !== null && val !== undefined) ? val : '--';
};

/**
 * 获取趋势颜色
 */
module.exports.getTrendColor = function(trend) {
  return trend === 'up' ? '#ff4d4f' : '#52c41a';
};

/**
 * 获取趋势文字
 */
module.exports.getTrendText = function(trend) {
  return trend === 'up' ? '↑ 预测涨' : '↓ 预测跌';
};
</wxs>

<view class="container">
  <!-- 预测表单 -->
  <view class="card">
    <text class="title">股票预测</text>
    <view class="form">
      <view class="form-item">
        <text class="label">股票代码</text>
        <input 
          class="input" 
          placeholder="如: 000001" 
          value="{{stockCode}}"
          bindinput="onInputChange"
          data-field="stockCode"
        />
      </view>
      <view class="form-item">
        <text class="label">预测天数</text>
        <picker mode="selector" range="{{dayRange}}" bindchange="onDaysChange">
          <view class="picker-value">{{predictDays}} 天</view>
        </picker>
      </view>
    </view>
    <button class="btn-predict" bindtap="doPredict" loading="{{predicting}}">
      {{predicting ? '预测中...' : '开始预测'}}
    </button>
  </view>

  <!-- 预测结果 -->
  <view class="card result-card" wx:if="{{result}}">
    <text class="title">预测结果</text>
    
    <!-- 股票信息 -->
    <view class="stock-info">
      <text class="stock-name">{{result.stock_name || stockCode}}</text>
      <text class="stock-code">{{result.stock_code}}</text>
    </view>

    <!-- 当前价格 -->
    <view class="current-price">
      <text class="label">当前价格</text>
      <text class="value">{{result.current_price}}</text>
    </view>

    <!-- 预测价格 -->
    <view class="predict-price">
      <view class="price-item" wx:if="{{result.predictions && result.predictions.length > 0}}">
        <text class="label">1天后</text>
        <text class="value" style="color: {{filters.getTrendColor(filters.getItem(result.predictions, 0).trend)}}">
          {{filters.getVal(filters.getItem(result.predictions, 0), 'price')}}
        </text>
        <text class="trend {{filters.getItem(result.predictions, 0).trend}}">
          {{filters.getTrendText(filters.getItem(result.predictions, 0).trend)}}
        </text>
      </view>
      <view class="price-item" wx:if="{{result.final_prediction}}">
        <text class="label">{{predictDays}}天后</text>
        <text class="value highlight">{{filters.getVal(result.final_prediction, 'price')}}</text>
        <text class="trend {{result.final_prediction.trend}}">
          {{filters.getTrendText(result.final_prediction.trend)}}
        </text>
      </view>
    </view>

    <!-- 置信度 -->
    <view class="confidence">
      <text class="label">预测置信度</text>
      <view class="confidence-bar">
        <view class="confidence-fill" style="width: {{result.confidence}}%"></view>
      </view>
      <text class="confidence-text">{{result.confidence}}%</text>
    </view>

    <!-- 风险提示 -->
    <view class="risk-tip">
      <text>⚠️ 预测结果仅供参考，不构成投资建议</text>
      <text>股市有风险，投资需谨慎</text>
    </view>
  </view>

  <!-- 历史预测 -->
  <view class="card history-card" wx:if="{{history.length > 0}}">
    <text class="title">历史预测</text>
    <view class="history-list">
      <view class="history-item" wx:for="{{history}}" wx:key="id">
        <view class="history-info">
          <text class="history-stock">{{item.stock_code}}</text>
          <text class="history-date">{{item.date}}</text>
        </view>
        <view class="history-result">
          <text>预测: {{item.predicted_price}}</text>
          <text>实际: {{item.actual_price || '待验证'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
